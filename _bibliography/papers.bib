@article{aghajaniasl2025islamicpcqa,
  title     = {IslamicPCQA: A Dataset for Persian Multi-hop Complex Question Answering in Islamic Text Resources},
  author    = {Ghafouri, Arash and Aghajani Asl, Mohammad and Naderi, Hassan and Firouzmandi, Mahdi},
  journal   = {IEEE Transactions on Audio, Speech and Language Processing},
  year      = {2025},
  month     = jul,
  publisher = {IEEE},
  html      = {https://ieeexplore.ieee.org/document/11075543},
  abstract  = {The first large-scale dataset (12,282 QA pairs) for complex multi-hop reasoning in Persian, built with graph-based construction methods. Covers bridge, comparative, and multi-constraint reasoning, with baseline benchmarking of multilingual models (XLM-RoBERTa, mBERT) for low-resource settings.},
  selected  = {true}
}

@article{aghajaniasl2025fairrag,
  title    = {FAIR-RAG: Faithful Adaptive Iterative Refinement for Retrieval-Augmented Generation},
  author   = {Aghajani Asl, Mohammad and Asgari-Bidhendi, Majid and Minaei-Bidgoli, Behrouz},
  journal  = {arXiv preprint arXiv:2510.22344},
  year     = {2025},
  month    = oct,
  eprint   = {2510.22344},
  archivePrefix = {arXiv},
  arxiv    = {2510.22344},
  html     = {https://arxiv.org/abs/2510.22344},
  note     = {Under review at Knowledge-Based Systems},
  abstract = {A novel agentic framework that turns standard RAG into a dynamic, multi-step reasoning process for complex multi-hop queries. Introduces Structured Evidence Assessment (SEA), a critic module that verifies evidence sufficiency before generation, and adaptive query refinement that targets identified knowledge gaps. Achieves state-of-the-art results on HotpotQA and 2WikiMultiHopQA, outperforming Self-RAG and Iter-RetGen by up to 8.3% F1.},
  selected = {true}
}

@article{aghajaniasl2025farsiqa,
  title    = {FARSIQA: Faithful & Advanced RAG System for Islamic Question Answering},
  author   = {Aghajani Asl, Mohammad and Minaei-Bidgoli, Behrouz},
  journal  = {arXiv preprint arXiv:2510.25621},
  year     = {2025},
  month    = oct,
  eprint   = {2510.25621},
  archivePrefix = {arXiv},
  arxiv    = {2510.25621},
  html     = {https://arxiv.org/abs/2510.25621},
  abstract = {A full-stack agentic QA system deploying the FAIR-RAG architecture in a high-stakes domain, with a knowledge base of over 1.7 million documents. Uses adaptive LLM routing (e.g., Llama 3 8B vs. 70B) to balance cost and latency, and achieves a 97% success rate in negative rejection (refusing out-of-scope queries).},
  selected = {true}
}
